{
  "name": "ai-setup",
  "version": "2.0.0",
  "description": "Config-driven macOS AI stack builder — extensible agent orchestrator",
  "type": "module",
  "bin": {
    "ai-setup": "./src/orchestrate.ts",
    "ai-nuke": "./src/nuke.ts",
    "ai-init": "./src/ai-init.ts"
  },
  "scripts": {
    "setup": "tsx src/orchestrate.ts",
    "nuke": "tsx src/nuke.ts",
    "init": "tsx src/ai-init.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
